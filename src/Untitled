:root {
  --bg-color: #f4f7f6;
  --text-color: #333;
  --card-bg: #ffffff;
  --table-header: #34495e;
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg-color: #121212;
    --text-color: #e0e0e0;
    --card-bg: #1e1e1e;
    --table-header: #000000;
  }
}

body {
  background-color: var(--bg-color);
  color: var(--text-color);
  transition:
    background-color 0.3s ease,
    color 0.3s ease;
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
}
